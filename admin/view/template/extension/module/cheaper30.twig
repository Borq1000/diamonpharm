				var name_text = '';
				_this.attr('name').split('!').forEach(function(i, item){
					if (item == 1) {
						name_text += '!' + value_row + '!';
					} else {
						name_text += i;
					}
				});
				_this.attr('name',name_text)
			});
			
			$('#body-value-' + row + ' button[onClick^=\'addSelectValue(\']').each(function(){
				$(this).attr('onClick','addSelectValue(\'' + $(this).attr('data-row') + '\',\'' + value_row + '\');');
			});
