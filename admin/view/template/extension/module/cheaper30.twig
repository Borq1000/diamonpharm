{{ header }}{{ column_left }}
 <div id="content">
   <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
		{% if module_id %}<button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-delete').submit() : false;"><i class="fa fa-trash-o"></i></button>{% endif %}
		<button onClick="formSubmit();" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary" id="save_click"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
	    {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	{% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	{% if text_info %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ text_info }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	<ul class="nav nav-tabs" id="tab">
		<li{% if module_id %} class="active"{% endif %}><a ref="#tab-guest"><i class="fa fa-list"></i> {{ cheapering }}</a></li>
		<li{% if not module_id %} class="active"{% endif %}><a ref="#tab-settings"><i class="fa fa-wrench"></i> {{ text_settings }}</a></li>
		<li><a ref="#tab-position"><i class="fa fa-th-list"></i> {{ text_position }}<span class="pro-style green">New</span></a></li>
		<li><a ref="#tab-template"><i class="fa fa-laptop"></i> {{ text_template }}<span class="pro-style green">New</span></a></li>
		<li><a ref="#tab-captcha"><i class="fa fa-android"></i> {{ text_captcha }}</a></li>
		<li><a ref="#tab-alerts"><i class="fa fa-bell-o"></i> {{ text_alerts }}<span class="pro-style green">New</span></a></li>
		<li><a ref="#tab-calculator"><i class="fa fa-calculator"></i> {{ text_calculator }}<span class="pro-style">Pro</span></a></li>
		<li><a ref="#tab-license"><i class="fa fa-thumbs-o-up"></i> {{ text_license }}</a></li>
		<li><a ref="#tab-help"><i class="fa fa-info"></i> {{ text_o_module }}</a></li>
	</ul>
    <div class="panel panel-default tab-content">
		<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal">
		<div class="tab-pane{% if not module_id %} active{% endif %}" id="tab-settings">
			<fieldset>
				<div class="form-group"><br /></div>
				<div class="form-group bg-gray">
					<div class="col-sm-12">
						<label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
						<div class="col-sm-10">
						  <select name="status" id="input-status" class="form-control">
							{% if status %}
							<option value="1" selected="selected">{{ text_enabled }}</option>
							<option value="0">{{ text_disabled }}</option>
							{% else %}
							<option value="1">{{ text_enabled }}</option>
							<option value="0" selected="selected">{{ text_disabled }}</option>
							{% endif %}
						  </select>
						</div>
					</div>
				</div>
				<div class="form-group"><br /></div>
				<div class="fields-text" id="select-text">
					<div class="form-group">
						<div class="col-sm-12">
							<label class="col-sm-2 control-label" for="input-name">{{ entry_name }}</label>
							<div class="col-sm-10">
							  <input type="text" name="name" value="{{ name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
							  {% if error_name %}
							  <div class="text-danger">{{ error_name }}</div>
							  {% endif %}
							</div>
						</div>
					</div>
					<div class="form-group fields-text">
						<label class="col-sm-2 control-label">{{ text_settings_text }}</label>
						<div class="col-sm-10">
							<div class="form-group">
								<div class="col-sm-3 text-right"><br /><label class="control-label">
									<span data-toggle="tooltip" title="" data-title="{{ help_text_tooltip_fields }}" style="font-weight: normal;">{{ text_h1_module }}</span>
								</label></div>
								<div class="col-sm-9">
									<div class="col-sm-12">
										<ul class="nav nav-tabs" id="language_h1">
											{% for language in languages %}
											<li><a href="#language_h1{{ language.language_id }}" data-toggle="tab" aria-expanded="true"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"> {{ language.name }}</a></li>
											{% endfor %}
										</ul>
										<div class="tab-content padding">
											{% for language in languages %}
												<div id="language_h1{{ language.language_id }}" class="tab-pane">
													<input type="text" name="cheaper30_h1[{{ language.language_id }}]" value="{% if cheaper30_h1[language.language_id] %}{{ cheaper30_h1[language.language_id] }}{% endif %}" placeholder="{{ text_select }}" class="form-control" maxlength="200" />
												</div>
											{% endfor %}
											{% if error_cheaper30_h1 %}
												<div class="text-danger">{{ error_cheaper30_h1 }}</div>
											{% endif %}
										</div>
									</div>
								</div>
							</div>
							<div class="form-group">
								<div class="col-sm-3 text-right"><br /><label>
									<span style="font-weight: normal;">{{ text_h4_module }}</span>
								</label></div>
								<div class="col-sm-9">
									<div class="col-sm-12">
										<ul class="nav nav-tabs" id="language_h4">
											{% for language in languages %}
											<li><a href="#language_h4{{ language.language_id }}" data-toggle="tab" aria-expanded="true"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"> {{ language.name }}</a></li>
											{% endfor %}
										</ul>
										<div class="tab-content padding">
											{% for language in languages %}
												<div id="language_h4{{ language.language_id }}" class="tab-pane">
													<input type="text" name="cheaper30_h4[{{ language.language_id }}]" value="{% if cheaper30_h4[language.language_id] %}{{ cheaper30_h4[language.language_id] }}{% endif %}" placeholder="{{ text_select }}" class="form-control" maxlength="200" />
												</div>
											{% endfor %}
										</div>
									</div>
								</div>
							</div>
							<div class="form-group">
								<div class="col-sm-3 text-right"><br /><label class="control-label">
									<span data-toggle="tooltip" title="" data-title="{{ help_text_tooltip_fields_required }}" style="font-weight: normal;">{{ text_succes_cheaper }}</span>
								</label></div>
								<div class="col-sm-9">
									<div class="col-sm-12">
										<ul class="nav nav-tabs" id="language_success">
											{% for language in languages %}
											<li><a href="#language_success{{ language.language_id }}" data-toggle="tab" aria-expanded="true"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"> {{ language.name }}</a></li>
											{% endfor %}
										</ul>
										<div class="tab-content padding">
											{% for language in languages %}
												<div id="language_success{{ language.language_id }}" class="tab-pane">
													<input type="text" name="cheaper30_succes[{{ language.language_id }}]" value="{% if cheaper30_succes[language.language_id] %}{{ cheaper30_succes[language.language_id] }}{% endif %}" placeholder="{{ text_select }}" class="form-control" maxlength="200" />
												</div>
											{% endfor %}
											{% if error_cheaper30_succes %}
												<div class="text-danger">{{ error_cheaper30_succes }}</div>
											{% endif %}
										</div>
									</div>
								</div>
							</div>
							<div class="form-group">
								<div class="col-sm-3 text-right"><br /><label class="control-label">
									<span data-toggle="tooltip" title="" data-title="{{ help_text_tooltip_fields_required }}" style="font-weight: normal;">{{ text_error_cheaper }}</span>
								</label></div>
								<div class="col-sm-9">
									<div class="col-sm-12">
										<ul class="nav nav-tabs" id="language_error">
											{% for language in languages %}
											<li><a href="#language_error{{ language.language_id }}" data-toggle="tab" aria-expanded="true"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"> {{ language.name }}</a></li>
											{% endfor %}
										</ul>
										<div class="tab-content padding">
											{% for language in languages %}
												<div id="language_error{{ language.language_id }}" class="tab-pane">
													<input type="text" name="cheaper30_errort[{{ language.language_id }}]" value="{% if cheaper30_errort[language.language_id] %}{{ cheaper30_errort[language.language_id] }}{% endif %}" placeholder="{{ text_select }}" class="form-control" maxlength="200" />
												</div>
											{% endfor %}
											{% if error_cheaper30_errort %}
												<div class="text-danger">{{ error_cheaper30_errort }}</div>
											{% endif %}
										</div>
									</div>
								</div>
							</div>
						</div><div class="clearfix"></div>
					</div>
					<div class="form-group fields-text">
						<label class="col-sm-2 control-label">{{ text_settings_input }}<br /><br /><br /><br />
						  <div class="well well-sm button-default">{{ entry_defaults }}<br /><br /><br />
							<span class="btn btn-primary" id="tableLoadcheaper" data-toggle="tooltip" type="button" title="{{ entry_defaults_1 }}" onClick="table_load('cheaper');"><i class="fa fa-level-down"></i> {{ help_entry_defaults_1 }}</span><br /><br />
							<span class="btn btn-primary" id="tableLoadquestion" data-toggle="tooltip" type="button" title="{{ entry_defaults_2 }}" onClick="table_load('question');"><i class="fa fa-question"></i> {{ help_entry_defaults_2 }}</span><br /><br />
							<span class="btn btn-primary" id="tableLoadsurvey" data-toggle="tooltip" type="button" title="{{ entry_defaults_3 }}" onClick="table_load('survey');"><i class="fa fa-bar-chart"></i> {{ help_entry_defaults_3 }}</span><br /><br />
							<span class="btn btn-primary" id="tableLoadcallback" data-toggle="tooltip" type="button" title="{{ entry_defaults_4 }}" onClick="table_load('callback');"><i class="fa fa-phone"></i> {{ help_entry_defaults_4 }}</span><br /><br /><br />
							{{ text_primer_calc_help }}
							<br /><br />
							<span class="btn btn-primary" id="tableLoadcredit" data-toggle="tooltip" type="button" title="{{ entry_defaults_5 }}" onClick="table_load('credit');"><i class="fa fa-rouble"></i> {{ help_entry_defaults_5 }}</span><br><br>
							<span class="btn btn-primary" id="tableLoadkirpish" data-toggle="tooltip" type="button" title="{{ entry_defaults_6 }}" onClick="table_load('kirpish');"><i class="fa fa-th"></i> {{ help_entry_defaults_6 }}</span><br /><br />
							<span class="btn btn-primary" id="tableLoadkrovla" data-toggle="tooltip" type="button" title="{{ entry_defaults_7 }}" onClick="table_load('zabor');"><i class="fa fa-building-o"></i> {{ help_entry_defaults_7 }}</span><br /><br />
						  </div>
						</label>
						<div class="col-sm-10"><div class="col-sm-12"><div>
							<fieldset class="fields-value-fieldset"><br />
							<div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_alert_position_8 }}</div><br />
							<table id="fields-value" class="table table-striped table-bordered table-hover">
							  <thead>
								<tr>
								  <td class="text-center">{{ entry_icons_fields }}</td>
								  <td class="text-left required">{{ entry_name_fields }}</td>
								  <td class="text-center">{{ entry_type_fields }}</td>
								  <td class="text-center">
									<label class="control-label"><span style="font-weight: normal;"  title="{{ help_entry_select_fields }}" data-toggle="tooltip">{{ entry_select_fields }}</span></label>
								  </td>
								  <td class="text-center">
									<label class="control-label"><span style="font-weight: normal;"  title="{{ help_entry_validation_fields }}" data-toggle="tooltip">{{ entry_validation_fields }}</span></label>
								  </td>
								  <td class="text-center">
									<label class="control-label"><span style="font-weight: normal;"  title="{{ help_entry_required_fields }}" data-toggle="tooltip">{{ entry_required_fields }}</span></label>
								  </td>
								  <td></td>
								</tr>
							  </thead>
							  <tbody><tr><td style="display: none;"></td></tr>
							  {% set fields_value_row = 1 %}
							  {% for field_value_id,result in results %}
							  <tr id="fields-value-row{{ result.id }}">
								<td class="nav text-center">
									<li>
									  <span type="text" class="btn btn-default icons" data-field="{{ result.id }}" onClick="selectIcons('{{ result.id }}'); return false;">{% if result.icon %}<i class="fa fa-{{ result.icon }}"></i>{% else %}{{ text_select_icons }}{% endif %}</span>
									  <input type="hidden" value="{% if result.icon %}{{ result.icon }}{% endif %}" name="field_value[{{ result.id }}][icon]">
									</li>
								</td>
								<td class="text-left"><input type="hidden" name="field_value[{{ result.id }}][field_value_id]" value="{{ result.id }}" />
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span><input type="text" name="field_value[{{ result.id }}][name][{{ language.language_id }}]" value="{{ result.name[language.language_id] }}" placeholder="{{ entry_name_fields }}" class="form-control name-fields" />
									</div>
									{% if error_name_field[field_value_id][language.language_id] %}
										<div class="text-danger">{{ error_name_field[field_value_id][language.language_id] }}</div>
									{% endif %}
								{% endfor %}
								</td>
								<td class="text-right">
									<select name="field_value[{{ result.id }}][type]" value=""  class="form-control select-regex" data-row="{{ result.id }}">
										{% for select in select_type %}
											<optgroup label="{{ select.text }}">
											{% for key,item in select.items %}
											<option value="{{ key }}"{% if key == result.type %} selected="selected"{% endif %}>{{ item }}</option>{% endfor %}</optgroup>
										{% endfor %}
									</select>
								</td>
								<td class="text-center parameter">
								{% if result.type == 'select' or result.type == 'radio' or result.type == 'checked' %}
									<div class="radio-div well well-sm">
										{% if result.query_value[result.id] %}
											<label class="checked_value control-label">{{ text_select_value }}</span></label>
											{% if result.type == 'select' %}
												<select class="form-control">
												{% for query_value in result.query_value[result.id] %}
													<optgroup label="{{ query_value.name[config_language_id] }}"></optgroup>
												{% endfor %}
												</select>
											{% endif %}
											{% if result.type == 'radio' %}
												{% for query_value in result.query_value[result.id] %}
													<label class="text-left"><input type="radio" disabled="disabled" /> {{ query_value.name[config_language_id] }}</label>
												{% endfor %}
											{% endif %}
											{% if result.type == 'checked' %}
												{% for query_value in result.query_value[result.id] %}
													<label class="text-left"><input type="checkbox" disabled="disabled" /> {{ query_value.name[config_language_id] }}</label>
												{% endfor %}
											{% endif %}
										{% else %}
											<label class="checked_value control-label">{{ text_select_value_empty }}</span></label>
										{% endif %}
									</div>
									<span class="btn btn-primary" data-toggle="tooltip" onClick="selectValue('{{ result.id }}','{{ result.type }}'); updateNumberValue('{{ result.id }}'); return false;" title="{{ button_field_parametr_add }}"><i class="fa fa-edit"></i></span>
								{% else %}-{% endif %}
								</td>
								<td class="text-center regex">
									{% if result.type == 'text' or result.type == 'textarea' %}
										<select name="field_value[{{ result.id }}][regex]" class="form-control type-regex select{{ result.id }}" data-row="{{ result.id }}">
											{% if result.type == 'text' %}
												{% for regex in code_regex_text %}
													<option value="{{ regex.valid }}"{% if result.regex == regex.valid %} selected="selected"{% endif %}>{{ regex.text }}</option>
												{% endfor %}
											{% endif %}
											{% if result.type == 'textarea' %}
												{% for regex in code_regex_textarea %}
													{% for reg,valid in regex.valid %}
														
													{% endfor %}
													<option value="{{ regex.valid }}"{% if result.regex == regex.valid %} selected="selected"{% endif %}>{{ regex.text }}</option>
												{% endfor %}
											{% endif %}
										</select><br />
										{% if result.regex == 'minlength' or result.regex == 'maxlength' or result.regex == 'max' or result.regex == 'min' or result.regex == 'step' %}
											<input type="text" class="form-control" placeholder="{{ result.placeholder }}" value="{{ result.valid }}" name="field_value[{{ result.id }}][valid]">
										{% endif %}
										{% if result.regex == 'rangelength' or result.regex == 'range' %}
											<div class="row">
												<div class="col-sm-6 col-xs-12"><input type="text" class="form-control" placeholder="{{ text_range_before }}" value="{{ result.valid.0 }}" name="field_value[{{ result.id }}][valid][0]"></div>
												<div class="col-sm-6 col-xs-12"><input type="text" class="form-control" placeholder="{{ text_range_after }}" value="{{ result.valid.1 }}" name="field_value[{{ result.id }}][valid][1]"></div>
											</div>
										{% endif %}
										{% if result.regex == 'phoneUS' %}
											<div class="input-group-phone">
												<label class="control-label" style="text-align: left; padding-bottom: 7px;"><span data-toggle="tooltip" title="{{ text_help_phoneUS }}" style="font-weight: normal;">{{ label_help_phoneUS }}</span></label>
												{% for language in languages %}
													<div class="input-group">
														<span class="input-group-addon"><img title="{{ language.name }}" src="language/{{ language.code }}/{{ language.code }}.png"></span>
														<input type="text" class="form-control" placeholder="{% if phones_placeholder[language.code] %}{{ phones_placeholder[language.code] }}{% else %}{{ text_phoneUS }}{% endif %}" value="{% if result.valid[language.code] %}{{ result.valid[language.code] }}{% endif %}" name="field_value[{{ result.id }}][valid][{{ language.code }}]">
													</div>
												{% endfor %}
											</div>
										{% endif %}
										{% if error_name_valid[fields_value_row] %}
											<div class="text-danger">{{ error_name_valid[fields_value_row] }}</div>
										{% endif %}
									{% else %}
										-
									{% endif %}
								</td>
								<td class="text-center"><label><input type="checkbox" name="field_value[{{ result.id }}][required]"{% if result.required %} checked="checked"{% endif %} value="1"></label><br /></td>
								<td class="text-right"><button type="button" onclick="$('#fields-value-row{{ result.id }}').remove(); testStorageFields();" data-toggle="tooltip" title="{{ text_remove_module }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
							  </tr>
							  {% set fields_value_row = fields_value_row + 1 %}
							  {% endfor %}
							  </tbody>
							  <tfoot>
								<tr>
								  <td colspan="6">
									{% if error_field_value %}
										<div class="text-danger"><br />{{ error_field_value }}<br /><br /></div>
									{% endif %}
								  </td>
								  <td class="text-right"><button type="button" onclick="addFieldValue();" data-toggle="tooltip" title="{{ button_field_value_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
								</tr>
							  </tfoot>
							</table>
						  </fieldset>
						</div></div></div>
					</div>
					<div id="select-value" class="col-lg-offset-3 col-lg-6 col-md-offset-3 col-md-6 col-sm-offset-2 col-sm-8 col-xs-offset-1 col-xs-10">
						<div class="select-value hide ps-3 pe-3">
							<div class="row">
								<h3><i class="fa fa-list-alt" aria-hidden="true"></i>&nbsp; {{ entry_value_fields_option }}</h3>
								<div class="close-cheaper" onclick="closeIcons('.select-value');"><svg class="svg-icon-cheaper"><use xlink:href="/catalog/view/javascript/cheaper30/icons.svg#svg-close"/></svg></div>
								{% if results %}
									{% set value_row = 0 %}
									{% for result in results %}{% set value_row = value_row + 1 %}
									<div class="col-sm-12 hide overf" id="body-value-{{ result.id }}">
										<div style="margin-top: 15px;">{{ text_sor }}</div>
										<table class="table table-striped table-bordered table-hover">
											<thead>
												<tr>
													<td class="text-center" width="1%">{{ text_head_value_1 }}</td>
													<td class="text-left">{{ text_head_value_2 }}</td>
													<td width="1%"></td>
												</tr>
											</thead>
											<tbody class="body-value" data-id="#body-value-{{ result.id }}"> 
											{% for query_row,query_value in result.query_value[result.id] %}
												{% set query_row = query_row + 1 %}
												<tr id="fields-value-{{ query_row }}" style="cursor: move;" class="ui-state-default">
													<td class="text-center cont-td">{{ query_row }}</td>
													<td class="text-left">
													{% for language in languages %}
														<div class="input-group">
															<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
															<input type="text" name="field_value[{{ result.id }}][!{{ result.type }}!][{{ query_row }}][{{ language.language_id }}]" value="{{ query_value.name[language.language_id] }}" placeholder="{{ entry_param_fields }}" class="form-control name-fields" data-language="{{ language.language_id }}" data-row="{{ result.id }}" data-type="{{ result.type }}" data-split-field-row="field_value[{{ result.id }}][!{{ result.type }}!][" data-split-language="][{{ language.language_id }}]" />
														</div>
													{% endfor %}
													</td>
													<td class="text-right">
														<button class="btn btn-danger" data-toggle="tooltip" onclick="$('#fields-value-{{ query_row }}').remove(); updateNumberValue({{ result.id }});" type="button" title="{{ text_remove_module }}"><i class="fa fa-minus-circle"></i></button>
													</td>
												</tr>
											{% endfor %}
												<tr>
													<td colspan="2"></td>
													<td>
														<button class="btn btn-success" data-toggle="tooltip" onclick="addSelectValue('{{ result.id }}','{{ result.type }}');" data-row="{{ result.id }}" type="button" title="{{ text_add_module }}"><i class="fa fa-plus-circle"></i></button>
													</td>
												</tr>
											</tbody>
										</table>
										<div class="container-fluid">
											<div class="pull-right"><span class="btn btn-primary" title="" data-toggle="tooltip" onclick="save{{ result.type }}Value('{{ result.id }}'); return false;" data-original-title="{{ button_save }}"><i class="fa fa-save"></i> {{ button_save }}</span></div>
