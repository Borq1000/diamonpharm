{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
	    <button onclick="$('#content #apply').attr('value', '1'); $('#' + $('#content form').attr('id')).submit();" data-toggle="tooltip" title="{{ button_apply }}" class="btn btn-success"><i class="fa fa-save"></i></button>
        <button type="submit" form="form-sticker" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	{% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-sticker" class="form-horizontal">
		  <input type="hidden" name="module_sticker_apply" id="apply" value="0" />
		  <ul class="nav nav-tabs">
            <li class="active"><a href="#tab-product" data-toggle="tab">{{ tab_product }}</a></li>
            <li><a href="#tab-category" data-toggle="tab">{{ tab_category }}</a></li>
          </ul>
		  <div class="tab-content">
			<div class="tab-pane active" id="tab-product">
			  <fieldset>
				<div class="form-group">
                  <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                  <div class="col-sm-9">
                    <select name="module_sticker_status" id="input-status" class="form-control">
                      {% if module_sticker_status %}
                      <option value="1" selected="selected">{{ text_enabled }}</option>
                      <option value="0">{{ text_disabled }}</option>
                      {% else %}
                      <option value="1">{{ text_enabled }}</option>
                      <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                    </select>
                  </div>
                </div>
			    <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-position">{{ entry_position }}  </label>
                  <div class="col-sm-9">
                    <select name="module_sticker_position" class="form-control" id="input-position">
				      {% if module_sticker_position == 'right' %}
				      <option value="right" selected="selected">{{ text_right }}</option>
				      <option value="left">{{ text_left }}</option>
				      {% else %}
				      <option value="right">{{ text_right }}</option>
				      <option value="left" selected="selected">{{ text_left }}</option>
				      {% endif %}
				    </select>
                  </div>
                </div>
			    <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-type">{{ entry_type }}</label>
                  <div class="col-sm-9">
                    <select name="module_sticker_type" class="form-control" id="input-type">
			          <option value="star"{% if module_sticker_type == 'star' %} selected="selected"{% endif %}>{{ text_star }}</option>
			          <option value="rectangle"{% if module_sticker_type == 'rectangle' %} selected="selected"{% endif %}>{{ text_rectangle }}</option>
					  <option value="ribbon"{% if module_sticker_type == 'ribbon' %} selected="selected"{% endif %}>{{ text_ribbon }}</option>
					  <option value="diagonal"{% if module_sticker_type == 'diagonal' %} selected="selected"{% endif %}>{{ text_diagonal }}</option>
				    </select>
                  </div>
                </div>
			  </fieldset>
			  <fieldset>
				<legend>{{ text_sticker_new }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-date-new">{{ entry_date_new }}</label>
				  <div class="col-sm-9">
					<select name="module_sticker_new[date_new]" id="input-date-new" class="form-control">
					  {% if module_sticker_new.date_new %}
					  <option value="1" selected="selected">{{ text_date_added }}</option>
					  <option value="0">{{ text_date_available }}</option>
					  {% else %}
					  <option value="1">{{ text_date_added }}</option>
					  <option value="0" selected="selected">{{ text_date_available }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-new-day">{{ entry_day }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_sticker_new[day]" value="{{ module_sticker_new.day }}" placeholder="{{ entry_day }}" id="input-new-day" class="form-control" />
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-new-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_sticker_new[status]" id="input-new-status" class="form-control">
					  {% if module_sticker_new.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-new-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_sticker_new[sort_order]" value="{{ module_sticker_new.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-new-sort-order" class="form-control" />
				  </div>
				</div>
			  </fieldset>
			  <fieldset>
				<legend>{{ text_sticker_bestseller }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-bestseller-sale">{{ entry_sale }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_sticker_bestseller[sale]" value="{{ module_sticker_bestseller.sale }}" placeholder="{{ entry_sale }}" id="input-bestseller-sale" class="form-control" />
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-bestseller-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_sticker_bestseller[status]" id="input-bestseller-status" class="form-control">
					  {% if module_sticker_bestseller.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-bestseller-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_sticker_bestseller[sort_order]" value="{{ module_sticker_bestseller.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-bestseller-sort-order" class="form-control" />
				  </div>
				</div>
			  </fieldset>
			  <fieldset>
				<legend>{{ text_sticker_special }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-special-label">{{ entry_label }}</label>
				  <div class="col-sm-9">
					<select name="module_sticker_special[label]" class="form-control" id="input-special-label">
					  {% if module_sticker_special.label == 2 %}
					  <option value="2" selected="selected">{{ text_label_text_percent }}</option>
					  <option value="1">{{ text_label_percent }}</option>
					  <option value="0">{{ text_label_text }}</option>
					  {% elseif module_sticker_sticker_special.label == 1 %}
					  <option value="2">{{ text_label_text_percent }}</option>
					  <option value="1" selected="selected">{{ text_label_percent }}</option>
					  <option value="0">{{ text_label_text }}</option>
					  {% else %}
					  <option value="2">{{ text_label_text_percent }}</option>
					  <option value="1">{{ text_label_percent }}</option>
					  <option value="0" selected="selected">{{ text_label_text }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-special-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_sticker_special[status]" id="input-special-status" class="form-control">
					  {% if module_sticker_special.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-special-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_sticker_special[sort_order]" value="{{ module_sticker_special.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-special-sort-order" class="form-control" />
				  </div>
				</div>
			  </fieldset>
			  <fieldset>
				<legend>{{ text_sticker_stock }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-stock-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_sticker_stock[status]" id="input-stock-status" class="form-control">
					  {% if module_sticker_stock.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-stock-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_sticker_stock[sort_order]" value="{{ module_sticker_stock.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-stock-sort-order" class="form-control" />
				  </div>
				</div>
			  </fieldset>
			  <fieldset>
				<legend>{{ text_sticker_price }}</legend>
				<div class="table-responsive">
				  <table id="sticker-price" class="table table-striped table-bordered table-hover">
					<thead>
					  <tr>
						<td class="text-left required">{{ entry_name }}</td>
						<td class="text-left">{{ entry_image }}</td>
						<td class="text-left">{{ entry_price }}</td>
						<td class="text-left">{{ entry_date }}</td>
						<td class="text-left">{{ entry_status }}</td>
						<td class="text-left">{{ entry_sort_order }}</td>
						<td></td>
					  </tr>
					</thead>
					<tbody>
					  {% set last_key_price = 0 %}
					  {% for key, sticker in module_sticker_price %}
					  <tr id="sticker-price-row{{ key }}">
						<td class="text-left">
						  {% for language in languages %}
						  <div class="input-group">
							<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
							<input type="text" name="module_sticker_price[{{ key }}][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="{{ sticker[language.language_id]['name'] }}" />
						  </div>
						  {% if error_sticker_price_name[key][language.language_id] is defined %}
						  <div class="text-danger">{{ error_sticker_price_name[key][language.language_id] }}</div>
						  {% endif %}
						  {% endfor %}
						</td>
						<td class="text-left">
						  <a href="" id="thumb-image-price{{ key }}" data-toggle="image" class="img-thumbnail"><img class="stickers" style="width: 70px;" src="{% if sticker.image %}/image/{{ sticker.image}}{% else %}{{ placeholder }}{% endif %}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_sticker_price[{{ key }}][image]" value="{{ sticker.image }}" class="input-stickers" id="input-image-price{{ key }}" />
						</td>
						<td class="text-left">
						  <input type="text" name="module_sticker_price[{{ key }}][min]" value="{{ sticker.min }}" placeholder="{{ entry_min }}" class="form-control" />
						  <input type="text" name="module_sticker_price[{{ key }}][max]" value="{{ sticker.max }}" placeholder="{{ entry_max }}" class="form-control" />
						</td>
						<td class="text-left">
						  <div class="input-group date">
						    <input type="text" name="module_sticker_price[{{ key }}][date_start]" value="{{ sticker.date_start }}" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						  <div class="input-group date">
						    <input type="text" name="module_sticker_price[{{ key }}][date_end]" value="{{ sticker.date_end }}" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						</td>
						<td class="text-left">
						  <select name="module_sticker_price[{{ key }}][status]" class="form-control">
							{% if sticker.status %}
							<option value="1" selected="selected">{{ text_enabled }}</option>
							<option value="0">{{ text_disabled }}</option>
							{% else %}
							<option value="1">{{ text_enabled }}</option>
							<option value="0" selected="selected">{{ text_disabled }}</option>
							{% endif %}
						  </select>
						</td>
						<td class="text-left">
						  <input type="text" name="module_sticker_price[{{ key }}][sort_order]" value="{{ sticker.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control" />
						</td>
						<td class="text-right"><button type="button" onclick="$('#sticker-price-row{{ key }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
					  </tr>
					  {% set last_key_price = key + 1 %}
					  {% endfor %}
					</tbody>
					<tfoot>
					  <tr>
						<td colspan="6"></td>
						<td class="text-right"><button type="button" onclick="addStickerPrice();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
					  </tr>
					</tfoot>
				  </table>
				</div>
			  </fieldset>
			  <fieldset>
				<legend>{{ text_sticker_custom }}</legend>
				<div class="table-responsive">
				  <table id="sticker-custom" class="table table-striped table-bordered table-hover">
					<thead>
					  <tr>
						<td class="text-left required">{{ entry_name }}</td>
						<td class="text-left">{{ entry_image }}</td>
						<td class="text-left">{{ entry_date }}</td>
						<td class="text-left">{{ entry_status }}</td>
						<td class="text-left">{{ entry_sort_order }}</td>
						<td></td>
					  </tr>
					</thead>
					<tbody>
					  {% set last_key_custom = 0 %}
					  {% for key, sticker in module_sticker_custom %}
					  <tr id="sticker-custom-row{{ key }}">
						<td class="text-left">
						  {% for language in languages %}
						  <div class="input-group">
							<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
							<input type="text" name="module_sticker_custom[{{ key }}][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="{{ sticker[language.language_id]['name'] }}" />
						  </div>
						  {% if error_sticker_custom_name[key][language.language_id] is defined %}
						  <div class="text-danger">{{ error_sticker_custom_name[key][language.language_id] }}</div>
						  {% endif %}
						  {% endfor %}
						</td>
						<td class="text-left">
						  <a href="" id="thumb-image-custom{{ key }}" data-toggle="image" class="img-thumbnail"><img class="stickers" style="width: 70px;" src="{% if sticker.image %}/image/{{ sticker.image }}{% else %}{{ placeholder }}{% endif %}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_sticker_custom[{{ key }}][image]" value="{{ sticker.image }}" class="input-stickers" id="input-image-custom{{ key }}" />
						</td>
						<td class="text-left">
						  <div class="input-group date">
						    <input type="text" name="module_sticker_custom[{{ key }}][date_start]" value="{{ sticker.date_start }}" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						  <div class="input-group date">
						    <input type="text" name="module_sticker_custom[{{ key }}][date_end]" value="{{ sticker.date_end }}" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						</td>
						<td class="text-left">
						  <select name="module_sticker_custom[{{ key }}][status]" class="form-control">
							{% if sticker.status %}
							<option value="1" selected="selected">{{ text_enabled }}</option>
							<option value="0">{{ text_disabled }}</option>
							{% else %}
							<option value="1">{{ text_enabled }}</option>
							<option value="0" selected="selected">{{ text_disabled }}</option>
							{% endif %}
						  </select>
						</td>
						<td class="text-left">
						  <input type="text" name="module_sticker_custom[{{ key }}][sort_order]" value="{{ sticker.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control" />
						</td>
						<td class="text-right"><button type="button" onclick="$('#sticker-custom-row{{ key }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
					  </tr>
					  {% set last_key_custom = key + 1 %}
					  {% endfor %}
					</tbody>
					<tfoot>
					  <tr>
						<td colspan="5"></td>
						<td class="text-right"><button type="button" onclick="addStickerCustom();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
					  </tr>
					</tfoot>
				  </table>
				</div>
			  </fieldset>
			</div>
			<div class="tab-pane" id="tab-category">
			  <div class="alert alert-warning"><i class="fa fa-exclamation-circle"></i> {{ text_no_sticker }}</div>
			</div>
		  </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
String.prototype.filename=function(extension){
	var s = this.replace(/\\/g, '/');
	return s.substring(s.lastIndexOf('/')+ 1);
}

$(document).ready(function() {
	$('#input-type').on('change', function() {
		$(".input-stickers").each(function(i) {
			var filename = $(this).val().filename();
			var folder = 'catalog/stickers/' + $('#input-type').val() + '/';
			$(this).val(folder + filename);
			$(this).prev().children().attr('src', '/image/' + folder + filename);
		});
	});
});

var key_price = {{ last_key_price }};

function addStickerPrice() {
    html  = '<tr id="sticker-price-row' + key_price + '">';
	html += '<td class="text-left">';
	{% for language in languages %}
	html += '<div class="input-group"><span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span><input type="text" name="module_sticker_price[' + key_price + '][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="" /></div>';
    {% endfor %}
	html += '</td>';
	html += '<td class="text-left">';
	html += '<a href="" id="thumb-image-price' + key_price + '" data-toggle="image" class="img-thumbnail"><img class="stickers" style="width: 70px;" src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_sticker_price[' + key_price + '][image]" value="" class="input-stickers" id="input-image-price' + key_price + '" />';
	html += '</td>';
	html += '<td class="text-left">';
	html += '<input type="text" name="module_sticker_price[' + key_price + '][min]" value="" placeholder="{{ entry_min }}" class="form-control" /><input type="text" name="module_sticker_price[' + key_price + '][max]" value="" placeholder="{{ entry_max }}" class="form-control" />';
	html += '</td>';
	html += '<td class="text-left">';
	html += '<div class="input-group date"><input type="text" name="module_sticker_price[' + key_price + '][date_start]" value="" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" /><span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span></div><div class="input-group date"><input type="text" name="module_sticker_price[' + key_price + '][date_end]" value="" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" /><span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span></div>';
	html += '</td>';
	html += '<td class="text-left">';
    html += '<select name="module_sticker_price[' + key_price + '][status]" class="form-control">';
	html += '<option value="1">{{ text_enabled }}</option>';
	html += '<option value="0" selected="selected">{{ text_disabled }}</option>';
    html += '</select>';
    html += '</td>';
	html += '<td class="text-left">';
	html += '<input type="text" name="module_sticker_price[' + key_price + '][sort_order]" value="" placeholder="{{ entry_sort_order }}" id="input-price-sort' + key_price + '" class="form-control" />';
	html += '</td>';
	html += '  <td class="text-right"><button type="button" onclick="$(\'#sticker-price-row' + key_price + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
    html += '</tr>';

	$('#sticker-price tbody').append(html);
	
	$('.date').datetimepicker({
		pickTime: false
	});
	
	key_price++;
}

var key_custom = {{ last_key_custom }};

function addStickerCustom() {
    html  = '<tr id="sticker-custom-row' + key_custom + '">';
	html += '<td class="text-left">';
	{% for language in languages %}
	html += '<div class="input-group"><span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span><input type="text" name="module_sticker_custom[' + key_custom + '][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="" /></div>';
    {% endfor %}
	html += '</td>';
	html += '<td class="text-left">';
	html += '<a href="" id="thumb-image-custom' + key_custom + '" data-toggle="image" class="img-thumbnail"><img class="stickers" style="width: 70px;" src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_sticker_custom[' + key_custom + '][image]" value="" class="input-stickers" id="input-image-custom' + key_custom + '" />';
	html += '</td>';
	html += '<td class="text-left">';
	html += '<div class="input-group date"><input type="text" name="module_sticker_custom[' + key_custom + '][date_start]" value="" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" /><span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span></div><div class="input-group date"><input type="text" name="module_sticker_custom[' + key_custom + '][date_end]" value="" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" /><span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span></div>';
	html += '</td>';
	html += '<td class="text-left">';
    html += '<select name="module_sticker_custom[' + key_custom + '][status]" class="form-control">';
	html += '<option value="1">{{ text_enabled }}</option>';
	html += '<option value="0" selected="selected">{{ text_disabled }}</option>';
    html += '</select>';
    html += '</td>';
	html += '<td class="text-left">';
	html += '<input type="text" name="module_sticker_custom[' + key_custom + '][sort_order]" value="" placeholder="{{ entry_sort_order }}" id="input-custom-sort' + key_custom + '" class="form-control" />';
	html += '</td>';
	html += '  <td class="text-right"><button type="button" onclick="$(\'#sticker-custom-row' + key_custom + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
    html += '</tr>';
	
	$('#sticker-custom tbody').append(html);
	
	$('.date').datetimepicker({
		pickTime: false
	});
	
	key_custom++;
}
//--></script>
<script type="text/javascript"><!--
$('.date').datetimepicker({
	pickTime: false
});
//--></script>
{{ footer }}