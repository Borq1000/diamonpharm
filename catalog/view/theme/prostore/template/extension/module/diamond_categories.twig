{# Diamond Categories Module - Frontend Template #}
{# Grid layout for categories display #}
{# Version: 1.0.0 #}

<div class="diamond-categories">
    <div class="container-fluid">
        {% if heading_title %}
        <span class="h2 products-featured__title">{{ heading_title }}</span>
        {% endif %}
        <div class="diamond-categories__grid diamond-categories__grid--cols-{{ columns }}">
            {% for category in categories %}
            <div class="diamond-category">
                <a href="{{ category.href }}" class="diamond-category__link">
                    <div class="diamond-category__image-wrapper">
                        <img src="{{ category.image }}" alt="{{ category.name }}" class="diamond-category__image" loading="lazy">
                        <div class="diamond-category__overlay">
                            <span class="diamond-category__count">{{ category.product_total }} {{ text_products }}</span>
                        </div>
                    </div>
                    <h3 class="diamond-category__name">{{ category.name }}</h3>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<style>
.diamond-categories {
    margin: 60px 0;
}

.diamond-categories .products-featured__title {
    margin-bottom: 40px;
    display: block;
}

.diamond-categories__grid {
    display: grid;
    gap: 30px;
}

.diamond-categories__grid--cols-2 {
    grid-template-columns: repeat(2, 1fr);
}

.diamond-categories__grid--cols-3 {
    grid-template-columns: repeat(3, 1fr);
}

.diamond-categories__grid--cols-4 {
    grid-template-columns: repeat(4, 1fr);
}

.diamond-categories__grid--cols-6 {
    grid-template-columns: repeat(6, 1fr);
}

.diamond-category {
    position: relative;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 2px 15px rgba(0,0,0,0.06);
}

.diamond-category:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
}

.diamond-category__link {
    display: block;
    text-decoration: none;
    color: inherit;
}

.diamond-category__link:hover {
    text-decoration: none;
}

.diamond-category__image-wrapper {
    position: relative;
    width: 100%;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #f8f9fa;
}

.diamond-category__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.diamond-category:hover .diamond-category__image {
    transform: scale(1.08);
}

.diamond-category__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.diamond-category:hover .diamond-category__overlay {
    opacity: 1;
}

.diamond-category__count {
    color: #fff;
    font-size: 14px;
    font-weight: 500;
}

.diamond-category__name {
    padding: 25px 20px;
    text-align: center;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.4;
    margin: 0;
    color: #333;
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.3s ease;
}

.diamond-category:hover .diamond-category__name {
    color: #116354;
}

/* Responsive Design */
@media (max-width: 1200px) {
    .diamond-categories__grid--cols-6 {
        grid-template-columns: repeat(4, 1fr);
    }
}

@media (max-width: 992px) {
    .diamond-categories__grid--cols-4,
    .diamond-categories__grid--cols-6 {
        grid-template-columns: repeat(3, 1fr);
    }
    
    .diamond-categories__title {
        font-size: 28px;
    }
}

@media (max-width: 768px) {
    .diamond-categories__grid--cols-3,
    .diamond-categories__grid--cols-4,
    .diamond-categories__grid--cols-6 {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .diamond-category__image-wrapper {
        height: 220px;
    }
    
    .diamond-category__name {
        font-size: 16px;
        padding: 20px 15px;
        min-height: 70px;
    }
}

@media (max-width: 576px) {
    .diamond-categories {
        margin: 40px 0;
    }
    
    .diamond-categories__title {
        font-size: 24px;
        margin-bottom: 30px;
    }
    
    .diamond-categories__grid {
        gap: 20px;
    }
    
    .diamond-category__image-wrapper {
        height: 180px;
    }
    
}
</style>
