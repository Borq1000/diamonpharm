	<!-- Categories :: Start-->
<div class="categories categories-standard">
	<div class="container-fluid">
		<span class="h2 categories__title">{% if title %}{{ title }}{% else %}{{ heading_title }}{% endif %}</span>
		<div class="categories__swiper">
			<div class="swiper-container swiper-categories swiper-categories--col-{{ column }} js-swiper-categories">
				<div class="swiper-wrapper">
					{% for i,banner1 in banners %}
					{% for banner in banner1 %}
					<div class="swiper-slide">
						<div class="categories__item categories__item--standard">
							<a href="{{ banner.link }}" class="categories__item-link-wrapper">
								<div class="categories__item-image-box">
									<img src="{{ banner.image }}" alt="{{ banner.title }}" class="categories__item-image" {% if lazyload %}loading="lazy"{% endif %}>
								</div>
								<h3 class="categories__item-title">{{ banner.title }}</h3>
							</a>
						</div>
					</div>
					{% endfor %}
					{% endfor %}
				</div>
			</div>
		</div>
	</div>
</div><!-- Categories :: End-->

<style>
.categories-standard {
	margin: 4rem 0;
}

.categories__item--standard {
	background: #fff;
	border-radius: 8px;
	overflow: hidden;
	transition: all 0.3s ease;
	height: 100%;
	border: 1px solid rgba(0,0,0,0.08);
}

.categories__item--standard:hover {
	box-shadow: 0 8px 24px rgba(0,0,0,0.1);
	transform: translateY(-4px);
}

.categories__item-link-wrapper {
	display: block;
	text-decoration: none;
	color: inherit;
	height: 100%;
}

.categories__item-image-box {
	width: 100%;
	height: 200px;
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	background: #f8f8f8;
	padding: 20px;
}

.categories__item--standard .categories__item-image {
	max-width: 100%;
	max-height: 100%;
	width: auto;
	height: auto;
	object-fit: contain;
}

.categories__item--standard .categories__item-title {
	padding: 20px;
	text-align: center;
	font-size: 18px;
	font-weight: 500;
	color: #333;
	margin: 0;
	line-height: 1.4;
	min-height: 60px;
	display: flex;
	align-items: center;
	justify-content: center;
}

/* Responsive adjustments */
@media (max-width: 768px) {
	.categories__item-image-box {
		height: 150px;
	}
	
	.categories__item--standard .categories__item-title {
		font-size: 16px;
		padding: 15px;
		min-height: 50px;
	}
}

@media (max-width: 576px) {
	.categories__item-image-box {
		height: 120px;
		padding: 15px;
	}
	
	.categories__item--standard .categories__item-title {
		font-size: 14px;
		padding: 12px;
		min-height: 40px;
	}
}
</style>